# GadgetGuru Environment Variables

# MongoDB Atlas connection string (Add your actual URI here)
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/<dbname>?retryWrites=true&w=majority

# SerpAPI key (get free key at https://serpapi.com)
SERP_API_KEY=your_serp_api_key_here

# Gmail SMTP for password reset emails (Use App Password)
MAIL_USER=your_email@gmail.com
MAIL_PASS=your_app_password

# JWT secret used for login token signing
JWT_SECRET=your_jwt_secret_here

# Port for backend server
PORT=5000
